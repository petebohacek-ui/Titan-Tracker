[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[remote "origin"]
	url = https://github.com/petebohacek-ui/Titan-Track.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main"]
	remote = titantracker
	vscode-merge-base = origin/main
	merge = refs/heads/main
[remote "titantracker"]
	url = https://github.com/petebohacek-ui/Titan-Tracker.git
	fetch = +refs/heads/*:refs/remotes/titantracker/*
